        else if(aItem.LHS_item.pItem.value.fType == STR and aItem.LHS_item.pItem.value.intersectPosParse == ipSquareBrackets and (aItem.RHS.looseType()) and aItem.RHS.pItem.value.fType == STR and aItem.RHS.pItem.value.format == fUnknown){
            //:l/merge::log(indentStr(aItem.indentLvl)+"        merge:lSTR|lintersect|==|rSTR|rfUnknown:TODO: unfinished")
        }
        else if(aItem.LHS_item.pItem.value.fType == STR and aItem.LHS_item.pItem.value.intersectPosParse == ipSquareBrackets and (aItem.RHS.looseType()) and aItem.RHS.pItem.value.fType == STR and aItem.RHS.pItem.value.format == fConcat){
            //:l/merge::log(indentStr(aItem.indentLvl)+"        merge:lSTR|lintersect|==|rSTR|rfConcat:TODO: unfinished")
        }
        else if(aItem.LHS_item.pItem.value.fType == STR and aItem.LHS_item.pItem.value.intersectPosParse == ipSquareBrackets and (aItem.RHS.looseType()) and aItem.RHS.pItem.value.fType == STR and aItem.RHS.pItem.value.format == fLiteral){
            //:l/merge::log(indentStr(aItem.indentLvl)+"        merge:lSTR|lintersect|==|rSTR|rfLiteral:TODO: unfinished")
        }
        else if(aItem.LHS_item.pItem.value.fType == STR and aItem.LHS_item.pItem.value.intersectPosParse == ipSquareBrackets and (aItem.RHS.looseType()) and aItem.RHS.pItem.value.fType == STR and aItem.RHS.pItem.intersectPos != ipNoIntersect){
            //:l/merge::log(indentStr(aItem.indentLvl)+"        merge:lSTR|lintersect|==|rSTR|rintersect:TODO: unfinished")
        }
        else if(aItem.LHS_item.pItem.value.fType == LST and aItem.LHS_item.pItem.value.format == fUnknown and (aItem.RHS.looseType()) and aItem.RHS.pItem.value.fType == LST and aItem.RHS.pItem.value.format == fConcat){
            //:l/merge::log(indentStr(aItem.indentLvl)+"        merge:lLST|lfUnknown|==|rLST|rfConcat:TODO: unfinished")
        }
        else if(aItem.LHS_item.pItem.value.fType == LST and aItem.LHS_item.pItem.value.format == fConcat and (aItem.RHS.looseType()) and aItem.RHS.pItem.value.fType == LST and aItem.RHS.pItem.value.format == fUnknown){
            //:l/merge::log(indentStr(aItem.indentLvl)+"        merge:lLST|lfConcat|==|rLST|rfUnknown:TODO: unfinished")
        }
        else if(aItem.LHS_item.pItem.value.fType == LST and aItem.LHS_item.pItem.value.format == fConcat and (aItem.RHS.looseType()) and aItem.RHS.pItem.value.fType == LST and aItem.RHS.pItem.value.format == fConcat){
            //:l/merge::log(indentStr(aItem.indentLvl)+"        merge:lLST|lfConcat|==|rLST|rfConcat:TODO: unfinished")
        }
        else if(aItem.LHS_item.pItem.value.fType == LST and aItem.LHS_item.pItem.value.format == fConcat and (aItem.RHS.looseType()) and aItem.RHS.pItem.value.fType == LST and aItem.RHS.pItem.value.format == fLiteral){
            //:l/merge::log(indentStr(aItem.indentLvl)+"        merge:lLST|lfConcat|==|rLST|rfLiteral:TODO: unfinished")
        }
        else if(aItem.LHS_item.pItem.value.fType == LST and aItem.LHS_item.pItem.value.format == fLiteral and (aItem.RHS.looseType()) and aItem.RHS.pItem.value.fType == LST and aItem.RHS.pItem.value.format == fConcat){
            //:l/merge::log(indentStr(aItem.indentLvl)+"        merge:lLST|lfLiteral|==|rLST|rfConcat:TODO: unfinished")
        }
        else if(aItem.LHS_item.pItem.value.fType == LST and aItem.LHS_item.pItem.value.intersectPosParse == ipSquareBrackets and (aItem.RHS.looseType()) and aItem.RHS.pItem.value.fType == LST and aItem.RHS.pItem.value.format == fUnknown){
            //:l/merge::log(indentStr(aItem.indentLvl)+"        merge:lLST|lintersect|==|rLST|rfUnknown:TODO: unfinished")
        }
        else if(aItem.LHS_item.pItem.value.fType == LST and aItem.LHS_item.pItem.value.intersectPosParse == ipSquareBrackets and (aItem.RHS.looseType()) and aItem.RHS.pItem.value.fType == LST and aItem.RHS.pItem.value.format == fConcat){
            //:l/merge::log(indentStr(aItem.indentLvl)+"        merge:lLST|lintersect|==|rLST|rfConcat:TODO: unfinished")
        }
        else if(aItem.LHS_item.pItem.value.fType == LST and aItem.LHS_item.pItem.value.intersectPosParse == ipSquareBrackets and (aItem.RHS.looseType()) and aItem.RHS.pItem.value.fType == LST and aItem.RHS.pItem.value.format == fLiteral){
            //:l/merge::log(indentStr(aItem.indentLvl)+"        merge:lLST|lintersect|==|rLST|rfLiteral:TODO: unfinished")
        }
        else if(aItem.LHS_item.pItem.value.fType == LST and aItem.LHS_item.pItem.value.intersectPosParse == ipSquareBrackets and (aItem.RHS.looseType()) and aItem.RHS.pItem.value.fType == LST and aItem.RHS.pItem.intersectPos != ipNoIntersect){
            //:l/merge::log(indentStr(aItem.indentLvl)+"        merge:lLST|lintersect|==|rLST|rintersect:TODO: unfinished")
        }
        else {log("MERGE_RULE_MISSING: "+ toString(aItem));log("          LHS fType:"+ fTypeStrings[aItem.LHS_item.pItem.value.fType]);log("          LHS format:"+ formatStrings[aItem.LHS_item.pItem.value.format]);log("          RHS fType:"+ fTypeStrings[aItem.RHS.pItem.value.fType]); log("EXITING"); exit(2);}
        return(remainder)
    }
    me bool: startPropRules(our AItem: aItem) <- {
        me bool: changeMade <- false
        if(!(aItem.RHS.looseType()) and !sizesAreCompatable(aItem.LHS_item.pItem, aItem.RHS.pItem)){
            //:l/merge::log(indentStr(aItem.indentLvl)+"        startProp  !looseSize|!sizesCompat||	REJECT")
            aItem.mergeStatus<-msReject; aItem.LHS_item.rejected<-true;
            changeMade <- true
        }
        else if(!(aItem.RHS.looseType()) and sizesAreCompatable(aItem.LHS_item.pItem, aItem.RHS.pItem) and (!aItem.LHS_item.pItem.value.tailUnfinished and aItem.LHS_item.pItem.value.items.size() == 0) and !(aItem.RHS.pItem.value.tailUnfinished and aItem.RHS.pItem.value.items.size()==0)){
            //:l/merge::log(indentStr(aItem.indentLvl)+"        startProp  !looseSize|sizesCompat|LHSEmpty|!RHSisPureDots	SKIP")
            //Skip
            changeMade <- true
        }
        else if(!(aItem.RHS.looseType()) and sizesAreCompatable(aItem.LHS_item.pItem, aItem.RHS.pItem) and (aItem.RHS.pItem.value.tailUnfinished and aItem.RHS.pItem.value.items.size()==0)){
            //:l/merge::log(indentStr(aItem.indentLvl)+"        startProp  !looseSize|sizesCompat||RHSisPureDots	initListIterators")
            initListIterators(aItem); aItem.mergeStatus<-msUnknown
            changeMade <- true
        }
        else if(!(aItem.RHS.looseType()) and sizesAreCompatable(aItem.LHS_item.pItem, aItem.RHS.pItem) and (aItem.LHS_item.pItem.value.tailUnfinished or aItem.LHS_item.pItem.value.items.size() > 0) and !(aItem.RHS.pItem.value.tailUnfinished and aItem.RHS.pItem.value.items.size()==0)){
            //:l/merge::log(indentStr(aItem.indentLvl)+"        startProp  !looseSize|sizesCompat|!LHSEmpty|!RHSisPureDots	initListIterators")
            initListIterators(aItem); aItem.mergeStatus<-msUnknown
            changeMade <- true
        }
        else if((aItem.RHS.looseType())){
            //:l/merge::log(indentStr(aItem.indentLvl)+"        startProp  looseSize|||	initListIterators")
            initListIterators(aItem); aItem.mergeStatus<-msUnknown
            changeMade <- true
        }
        //else {log("@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@ startProp RULE_MISSING");}
        return(changeMade)
    }
}
