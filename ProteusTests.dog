    const string: unS1_In <- "{@color={hue, bright, saturation}}\n{_ color _ _}={2 color:{hue:5, bright:6, saturation:7} 3 _=4}"
    const string: unS1_Out <- "{2 color:{hue:5, bright:6, saturation:7} 3 4}"
